# ── NeuroScanBalance – ALL-INKL / Apache ──

DirectoryIndex index.html index.htm
AddDefaultCharset UTF-8
Options -MultiViews

# Interne Dateien vor Web-Zugriff schützen (SMTP-/Admin-Zugangsdaten, Zahlungsdaten, Formular-Log)
# termine.json bleibt ABSICHTLICH öffentlich lesbar (Startseite + Anmeldeformular
# laden Termine/Preise per fetch() – enthält keine Bankdaten).
<FilesMatch "^(smtp-config\.php|smtpconfig\.php|formular-log\.txt|zahlung-config\.php|admin-config\.php)$">
  Require all denied
</FilesMatch>

# ══════════════════════════════════════════════════════════
# KANONISCHE DOMAIN ERZWINGEN
# Verhindert doppelten Inhalt (SEO) durch http:// bzw. www.-Varianten.
# Ziel: https://neuroscanbalance-badessen.de/ (siehe <link rel="canonical">)
# Maximal 2 Redirects, keine Schleife: nach jedem Schritt greift die
# jeweilige RewriteCond nicht mehr erneut.
# ══════════════════════════════════════════════════════════
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1) HTTP -> HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2) www. -> ohne www (kanonische Domain)
  RewriteCond %{HTTP_HOST} ^www\.neuroscanbalance-badessen\.de$ [NC]
  RewriteRule ^ https://neuroscanbalance-badessen.de%{REQUEST_URI} [L,R=301]
</IfModule>

# ══════════════════════════════════════════════════════════
# KOMPRESSION KOMPLETT ABSCHALTEN
# ALL-INKL liefert kaputte gzip-Streams (leere/defekte Antwort)
# → weiße Seite. Kompression bringt hier nur ~26 KB, verursacht
# aber Ausfälle. Daher: komplett aus.
# ══════════════════════════════════════════════════════════

# 1) mod_deflate (Apache-Kompression) für ALLES deaktivieren
<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI .* no-gzip dont-vary
</IfModule>

# 2) Server-eigene Kompression über SetEnv abschalten
SetEnv no-gzip 1
SetEnv dont-vary 1

# 3) Dem Server die "kann komprimiert"-Anfrage des Browsers wegnehmen
<IfModule mod_headers.c>
  RequestHeader unset Accept-Encoding
  Header unset Content-Encoding
  Header unset Vary
</IfModule>

# 4) mod_gzip (falls aktiv) aus
<IfModule mod_gzip.c>
  mod_gzip_on No
</IfModule>

# 5) Brotli (falls aktiv) aus
<IfModule mod_brotli.c>
  SetEnv no-brotli 1
</IfModule>

# ── Browser-Caching für statische Assets ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
